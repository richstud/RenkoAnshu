[Unit]
Description=Renko Trading Bot Strategy Worker
After=network.target renko-backend.service
Wants=renko-backend.service

[Service]
Type=simple
User=renko
WorkingDirectory=/home/renko/renko
Environment="PATH=/home/renko/renko/.venv/bin"
ExecStart=/home/renko/renko/.venv/bin/python backend/worker.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
