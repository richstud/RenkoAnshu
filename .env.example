# ===================================
# RENKO TRADING BOT - ENVIRONMENT VARIABLES
# ===================================
# Copy this file to .env and fill in your actual values

# ===================================
# SUPABASE CONFIGURATION
# ===================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_DB_SCHEMA=public

# ===================================
# MT5 CONFIGURATION
# ===================================
# Path to MetaTrader 5 installation
# Windows example: C:\Program Files\MetaTrader 5\terminal64.exe
# Or just directory: C:\Program Files\MetaTrader 5
MT5_PATH=C:\Program Files\MetaTrader 5

# ===================================
# RENKO STRATEGY PARAMETERS
# ===================================
# Default brick size (in pips)
RENKO_BRICK_SIZE=1.0

# Default trading symbol (can be overridden per watchlist item)
SYMBOL=XAUUSD

# ===================================
# BOT POLLING & PERFORMANCE
# ===================================
# How often to check for new signals (in seconds)
POLL_INTERVAL=0.5

# Max concurrent positions per account
MAX_TRADE_SIDE=1

# ===================================
# ENVIRONMENT
# ===================================
# development, staging, production
ENVIRONMENT=development

# ===================================
# FASTAPI SERVER
# ===================================
# Host to bind to (0.0.0.0 for external access)
API_HOST=0.0.0.0
API_PORT=8000

# ===================================
# OPTIONAL: LOGGING & DEBUG
# ===================================
# LOG_LEVEL=INFO
# DEBUG=false

# ===================================
# OPTIONAL: VPS SPECIFIC
# ===================================
# For VPS deployment
# REDIS_URL=redis://localhost:6379
# WORKERS=4
